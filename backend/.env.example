# Application
APP_NAME="Multi-Disease Prediction System"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://mdps_user:mdps_pass@localhost:5432/mdps_db
SYNC_DATABASE_URL=postgresql://mdps_user:mdps_pass@localhost:5432/mdps_db

# Paths
MODEL_SAVE_PATH=./ml/saved_models
REPORT_SAVE_PATH=./reports
DATA_PATH=./ml/data

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
